---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Contact from '../components/Contact.astro';
import ServiceFolder from '../components/ServiceFolder.astro';
import DossierDialogs from '../components/DossierDialogs.astro';
import { folders } from '../portfolio';
---

<Layout
  title="Dossiers — FromWhere Studio · Notre façon de travailler"
  description="Ouvrez nos dossiers : podcasts, réseaux sociaux, interviews, publicités, stratégies et ads. Notre méthode, service par service, et les projets qu’on en a sortis."
>
  <Nav />

  <main class="folders-page">
    <div class="container">
      <header class="folders-head">
        <div class="kicker">Le classeur — comment on travaille</div>
        <h1 class="folders-title">Ouvrez un dossier.</h1>
        <p class="folders-lead">
          Six services, six façons de bosser. Cliquez sur un dossier pour découvrir
          notre méthode — et les projets qu’on en a sortis.
        </p>
      </header>

      <div class="folder-grid">
        {folders.map((f) => <ServiceFolder f={f} />)}
      </div>
    </div>
  </main>

  <DossierDialogs />

  <Contact />
</Layout>

<style>
  .folders-page { padding-top: 64px; padding-bottom: 96px; }

  .folders-head { max-width: 640px; margin-bottom: 56px; }
  .folders-title {
    font-family: var(--font-title);
    font-weight: 800;
    font-size: clamp(46px, 6vw, 84px);
    line-height: .86;
    letter-spacing: -.04em;
    margin: 0;
  }
  .folders-lead {
    font-size: 17px;
    line-height: 1.55;
    color: var(--text-muted);
    margin: 24px 0 0;
  }

  .folder-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px 28px;
  }

  @media (max-width: 980px) {
    .folder-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .folder-grid { grid-template-columns: 1fr; }
  }
</style>
