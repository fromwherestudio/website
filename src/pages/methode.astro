---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Contact from '../components/Contact.astro';

// ===== Les 4 protocoles (phases du système) =====
const phases = [
  {
    n: '01',
    color: 'var(--bleu)',
    ink: '#1f3548',
    name: 'Stratégie & écriture',
    aim: 'On définit l’angle avant tout.',
    in: ['Brief', 'Audience cible', 'Objectif'],
    method: ['Angle éditorial', 'Choix du format', 'Plan de contenu'],
    out: ['Note d’intention', 'Script', 'Plan de tournage'],
    vars: ['Accroche', 'Ton', 'Structure', 'Promesse'],
  },
  {
    n: '02',
    color: 'var(--jaune)',
    ink: '#473a12',
    name: 'Production & captation',
    aim: 'On capte la matière, proprement.',
    in: ['Script', 'Décor / lieu'],
    method: ['Captation multi-caméra', 'Lumière', 'Prise de son'],
    out: ['Rushes', 'Sons sources'],
    vars: ['Cadrage', 'Lumière', 'Direction', 'Plateau'],
  },
  {
    n: '03',
    color: 'var(--vert)',
    ink: '#26361d',
    name: 'Post-production',
    aim: 'On donne le rythme et la forme.',
    in: ['Rushes', 'Sons'],
    method: ['Montage', 'Étalonnage', 'Motion & habillage'],
    out: ['Master', 'Déclinaisons réseaux'],
    vars: ['Rythme', 'Colorimétrie', 'Sound design', 'Sous-titres'],
  },
  {
    n: '04',
    color: 'var(--ink)',
    ink: '#F2EBDD',
    dark: true,
    name: 'Diffusion & acquisition',
    aim: 'On amène le contenu à son audience.',
    in: ['Master', 'Déclinaisons'],
    method: ['Calendrier', 'Publication', 'Campagnes Ads', 'A/B testing'],
    out: ['Audience', 'Résultats', 'Reporting'],
    vars: ['Algorithme', 'Ciblage', 'CPM / ROAS', 'Communauté'],
  },
];

// ===== Le champ d'étude (index des sujets) =====
const fields = [
  { domain: 'Narration', topics: ['Angle', 'Accroche', 'Storytelling', 'Structure', 'Ton de marque', 'Promesse'] },
  { domain: 'Image', topics: ['Cadrage', 'Lumière', 'Décor', 'Direction artistique', 'Étalonnage', 'Colorimétrie'] },
  { domain: 'Son', topics: ['Prise de son', 'Mixage', 'Sound design', 'Musique', 'Voix'] },
  { domain: 'Rythme', topics: ['Montage', 'Jump cut', 'Motion design', 'Habillage', 'Sous-titres'] },
  { domain: 'Formats', topics: ['16:9', '9:16', 'Reels', 'TikTok', 'Shorts', 'YouTube', 'Durée'] },
  { domain: 'Diffusion', topics: ['Calendrier éditorial', 'Algorithme', 'Ciblage', 'A/B testing', 'CPM', 'ROAS', 'Reporting', 'Communauté'] },
];

// ===== Les lois du studio =====
const laws = [
  'Si ça ne se regarde pas jusqu’au bout, ça n’existe pas.',
  'La stratégie se décide avant d’allumer la caméra.',
  'Un jour de tournage doit nourrir un mois de contenu.',
  'Ce qui n’est pas mesuré ne s’améliore pas.',
];
---

<Layout
  title="Méthode — FromWhere Studio · Notre système créatif"
  description="Le système créatif de FromWhere Studio : un protocole en 4 phases, de l’intention à la diffusion. La création traitée comme un système — rigoureux, mesurable, jamais froid."
>
  <Nav />

  <main class="methode">
    <div class="methode__grid-bg" aria-hidden="true"></div>

    <!-- ===== Manifeste ===== -->
    <section class="container methode__intro">
      <div class="kicker">Protocole — comment naît un contenu</div>
      <h1 class="methode__title">Notre <span class="i">système</span> créatif.</h1>
      <p class="methode__lead">
        On traite la création comme un système : observable, répétable, mesurable —
        et jamais froid. Chaque contenu suit le même protocole, de l’intention
        jusqu’à la dernière vue.
      </p>
      <div class="equation">
        <span class="equation__pair"><span class="equation__term">Intention</span><span class="equation__op">×</span></span>
        <span class="equation__pair"><span class="equation__term">Exécution</span><span class="equation__op">×</span></span>
        <span class="equation__pair"><span class="equation__term">Diffusion</span><span class="equation__op">=</span></span>
        <span class="equation__term equation__term--res">Attention</span>
      </div>
    </section>

    <!-- ===== Schéma du système ===== -->
    <section class="container schema">
      <div class="schema__fig">FIG. 01 — Flux du système</div>
      <div class="schema__row">
        <div class="schema__io">
          <div class="schema__io-label">Entrées</div>
          <ul>
            <li>Brief</li>
            <li>Audience</li>
            <li>Objectif</li>
          </ul>
        </div>
        <div class="schema__arrow" aria-hidden="true">→</div>
        <div class="schema__core">
          <div class="schema__core-label">Procédé — 4 phases</div>
          <div class="schema__phases">
            {phases.map((p) => (
              <span class="schema__phase" style={`background:${p.color};color:${p.ink}`}>{p.n}</span>
            ))}
          </div>
        </div>
        <div class="schema__arrow" aria-hidden="true">→</div>
        <div class="schema__io">
          <div class="schema__io-label">Sorties</div>
          <ul>
            <li>Formats</li>
            <li>Diffusion</li>
            <li>Résultats</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ===== Les 4 protocoles ===== -->
    <section class="container protocoles">
      <div class="protocoles__head">
        <div class="kicker">Le protocole, phase par phase</div>
        <h2 class="section-title">Quatre phases,<br />une seule trajectoire.</h2>
      </div>

      <div class="protocoles__list">
        {phases.map((p) => (
          <article class={`proto ${p.dark ? 'proto--dark' : ''}`} style={`--c:${p.color};--cink:${p.ink}`}>
            <div class="proto__side">
              <div class="proto__n">{p.n}</div>
              <div class="proto__name">{p.name}</div>
              <div class="proto__aim">{p.aim}</div>
            </div>
            <div class="proto__io">
              <div class="proto__col">
                <div class="proto__col-h">Entrées</div>
                <ul>{p.in.map((x) => <li>{x}</li>)}</ul>
              </div>
              <div class="proto__col">
                <div class="proto__col-h">Méthode</div>
                <ul>{p.method.map((x) => <li>{x}</li>)}</ul>
              </div>
              <div class="proto__col">
                <div class="proto__col-h">Sorties</div>
                <ul>{p.out.map((x) => <li>{x}</li>)}</ul>
              </div>
            </div>
            <div class="proto__vars">
              <span class="proto__vars-h">Variables</span>
              {p.vars.map((v) => <span class="proto__var">{v}</span>)}
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- ===== Le champ d'étude (index) ===== -->
    <section class="container champ">
      <div class="champ__head">
        <div class="kicker">Le champ d’étude</div>
        <h2 class="section-title">Tout ce qu’un bon contenu<br />met en jeu.</h2>
        <p class="champ__lead">
          Derrière chaque dossier, des dizaines de paramètres qu’on règle un par un.
          Voici notre terrain de jeu.
        </p>
      </div>
      <div class="champ__grid">
        {fields.map((f) => (
          <div class="champ__domain">
            <div class="champ__domain-h">{f.domain}</div>
            <div class="champ__tags">
              {f.topics.map((t) => <span class="champ__tag">{t}</span>)}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ===== Les lois du studio ===== -->
    <section class="laws-section">
      <div class="container">
        <div class="kicker" style="color:var(--kraft)">Les lois du studio</div>
        <ol class="laws">
          {laws.map((l, i) => (
            <li class="law">
              <span class="law__n">Loi n°{i + 1}</span>
              <span class="law__txt">{l}</span>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- ===== CTA ===== -->
    <section class="container methode__cta">
      <h2 class="methode__cta-title">On applique tout ça<br />à votre projet ?</h2>
      <div class="methode__cta-row">
        <a href="/#brief" class="btn btn-solid">Ouvrir un dossier →</a>
        <a href="/#services" class="btn btn-outline">Voir ce qu’on fait</a>
      </div>
    </section>
  </main>

  <Contact />
</Layout>

<style>
  .methode { position: relative; padding-bottom: 100px; overflow: hidden; }
  /* papier millimétré (look scientifique) */
  .methode__grid-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: .5;
    background-image:
      linear-gradient(rgba(34, 31, 24, .05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(34, 31, 24, .05) 1px, transparent 1px);
    background-size: 28px 28px;
    mask-image: linear-gradient(to bottom, #000 0, #000 60%, transparent 100%);
  }
  .methode > * { position: relative; z-index: 1; }

  /* ===== Manifeste ===== */
  .methode__intro { padding-top: 72px; max-width: 820px; }
  .methode__title {
    font-family: var(--font-title);
    font-weight: 800;
    font-size: clamp(46px, 6.4vw, 92px);
    line-height: .86;
    letter-spacing: -.04em;
    margin: 0;
  }
  .methode__title .i { font-style: italic; font-weight: 600; }
  .methode__lead {
    font-size: 18px;
    line-height: 1.55;
    color: var(--text-muted);
    max-width: 560px;
    margin: 26px 0 0;
  }
  .equation {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    margin-top: 36px;
  }
  .equation__pair {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    white-space: nowrap;
  }
  .equation__term {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: .04em;
    border: var(--border);
    background: var(--paper);
    padding: 9px 14px;
  }
  .equation__term--res { background: var(--jaune); }
  .equation__op { font-family: var(--font-title); font-weight: 800; font-size: 20px; }

  /* ===== Schéma ===== */
  .schema { padding-top: 72px; }
  .schema__fig {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--label-muted);
    margin-bottom: 16px;
  }
  .schema__row {
    display: flex;
    align-items: stretch;
    gap: 14px;
    border: var(--border);
    background: var(--paper);
    box-shadow: var(--shadow);
    padding: 26px;
  }
  .schema__io { flex: 1; }
  .schema__io-label, .schema__core-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--kraft-text);
    margin-bottom: 12px;
  }
  .schema__io ul { margin: 0; padding-left: 18px; }
  .schema__io li { font-size: 15px; line-height: 1.7; }
  .schema__arrow {
    align-self: center;
    font-family: var(--font-title);
    font-weight: 800;
    font-size: 26px;
    color: var(--kraft-text);
  }
  .schema__core { flex: 1.3; border-left: 1.5px dashed #b3a079; border-right: 1.5px dashed #b3a079; padding: 0 20px; }
  .schema__phases { display: flex; gap: 10px; }
  .schema__phase {
    width: 44px;
    height: 44px;
    border: var(--border);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-title);
    font-weight: 800;
    font-size: 15px;
  }

  /* ===== Protocoles ===== */
  .protocoles { padding-top: 96px; }
  .protocoles__head { margin-bottom: 40px; }
  .protocoles__head .kicker { color: var(--kraft-text); }
  .protocoles__list { display: flex; flex-direction: column; gap: 20px; }
  .proto {
    display: grid;
    grid-template-columns: 240px 1fr;
    border: var(--border);
    background: var(--paper);
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  .proto__side {
    background: var(--c);
    color: var(--cink);
    padding: 26px;
    border-right: var(--border);
  }
  .proto__n { font-family: var(--font-mono); font-size: 12px; letter-spacing: .14em; }
  .proto__name {
    font-family: var(--font-title);
    font-weight: 800;
    font-size: 22px;
    letter-spacing: -.02em;
    line-height: 1.05;
    margin-top: 10px;
  }
  .proto__aim { font-size: 14px; line-height: 1.45; margin-top: 10px; opacity: .85; }

  .proto__io { display: grid; grid-template-columns: repeat(3, 1fr); }
  .proto__col { padding: 22px; border-right: 1.5px dashed #d8cbb0; }
  .proto__col:last-child { border-right: none; }
  .proto__col-h {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--kraft-text);
    margin-bottom: 12px;
  }
  .proto__col ul { margin: 0; padding-left: 16px; }
  .proto__col li { font-size: 14.5px; line-height: 1.65; color: var(--text-muted); }

  .proto__vars {
    grid-column: 1 / -1;
    border-top: var(--border);
    padding: 16px 22px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    background: var(--carton-light);
  }
  .proto__vars-h {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--label-muted);
    margin-right: 6px;
  }
  .proto__var {
    font-family: var(--font-mono);
    font-size: 11px;
    border: 1.5px solid var(--ink);
    border-radius: 999px;
    padding: 4px 11px;
    background: var(--paper);
  }
  .proto--dark .proto__io { background: #221F18; }
  .proto--dark .proto__col li { color: #cfc6b2; }
  .proto--dark .proto__col { border-right-color: #4a463c; }
  .proto--dark .proto__vars { background: #2a261d; }
  .proto--dark .proto__var { background: #221F18; color: #F2EBDD; border-color: #6a6456; }
  .proto--dark .proto__vars-h { color: #bdb29a; }

  /* ===== Champ d'étude ===== */
  .champ { padding-top: 100px; }
  .champ__head { max-width: 640px; margin-bottom: 40px; }
  .champ__head .kicker { color: var(--kraft-text); }
  .champ__lead { font-size: 16px; line-height: 1.55; color: var(--text-muted); margin: 18px 0 0; }
  .champ__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .champ__domain {
    border: var(--border);
    background: var(--paper);
    box-shadow: var(--shadow-sm);
    padding: 20px;
  }
  .champ__domain-h {
    font-family: var(--font-title);
    font-weight: 800;
    font-size: 18px;
    letter-spacing: -.01em;
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 1.5px dashed #d8cbb0;
  }
  .champ__tags { display: flex; flex-wrap: wrap; gap: 7px; }
  .champ__tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .02em;
    border: 1.5px solid var(--ink);
    padding: 4px 10px;
    background: var(--carton-light);
  }

  /* ===== Lois ===== */
  .laws-section {
    margin-top: 100px;
    background: var(--ink);
    color: var(--paper);
    border-top: var(--border);
    border-bottom: var(--border);
    padding: 80px 0;
  }
  .laws { list-style: none; margin: 28px 0 0; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
  .law {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 28px 28px 28px 0;
    border-top: 1px solid #3a362c;
  }
  .law__n { font-family: var(--font-mono); font-size: 12px; letter-spacing: .14em; color: var(--jaune); }
  .law__txt {
    font-family: var(--font-title);
    font-weight: 700;
    font-size: clamp(20px, 2vw, 26px);
    letter-spacing: -.02em;
    line-height: 1.1;
  }

  /* ===== CTA ===== */
  .methode__cta { padding-top: 90px; text-align: center; }
  .methode__cta-title {
    font-family: var(--font-title);
    font-weight: 800;
    font-size: clamp(34px, 4.4vw, 58px);
    line-height: .95;
    letter-spacing: -.03em;
    margin: 0 0 28px;
  }
  .methode__cta-row { display: flex; gap: 13px; justify-content: center; flex-wrap: wrap; }

  /* ===== Responsive ===== */
  @media (max-width: 860px) {
    .schema__row { flex-direction: column; }
    .schema__arrow { transform: rotate(90deg); }
    .schema__core { border: none; border-top: 1.5px dashed #b3a079; border-bottom: 1.5px dashed #b3a079; padding: 18px 0; }
    .proto { grid-template-columns: 1fr; }
    .proto__side { border-right: none; border-bottom: var(--border); }
    .proto__io { grid-template-columns: 1fr; }
    .proto__col { border-right: none; border-bottom: 1.5px dashed #d8cbb0; }
    .champ__grid { grid-template-columns: 1fr 1fr; }
    .laws { grid-template-columns: 1fr; }
    .law { padding-right: 0; }
  }
  @media (max-width: 560px) {
    .champ__grid { grid-template-columns: 1fr; }
  }
</style>
