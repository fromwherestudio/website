---
const steps = [
  {
    n: '01', bg: 'var(--bleu)', dark: false,
    labelColor: '#1f3548', titleColor: '#1f3548', textColor: '#274055',
    label: 'STRATÉGIE & ÉCRITURE', title: 'On définit l’angle',
    desc: 'Format, message, plan de contenu. La stratégie se décide avant d’allumer la caméra.',
  },
  {
    n: '02', bg: 'var(--jaune)', dark: false,
    labelColor: '#5a4a18', titleColor: '#473a12', textColor: '#5a4a18',
    label: 'PRODUCTION & CAPTATION', title: 'On tourne',
    desc: 'Captation multi-caméra, lumière, prise de son. En studio ou en décor réel.',
  },
  {
    n: '03', bg: 'var(--vert)', dark: false,
    labelColor: '#26361d', titleColor: '#26361d', textColor: '#34452a',
    label: 'POST-PRODUCTION', title: 'On monte',
    desc: 'Montage, étalonnage, motion, habillage — et les déclinaisons pour chaque écran.',
  },
  {
    n: '04', bg: 'var(--ink)', dark: true,
    labelColor: '#EFD27E', titleColor: '#F2EBDD', textColor: '#cfc6b2',
    label: 'DIFFUSION & ACQUISITION', title: 'On amène à l’audience',
    desc: 'Calendrier de publication, réseaux sociaux, campagnes ads. Le contenu doit performer, pas juste exister.',
  },
];
---

<section id="capacites" class="container methode">
  <div class="methode__head">
    <div>
      <div class="kicker">02 — Comment on travaille</div>
      <h2 class="section-title methode__title">
        Un studio complet,<br />de l’idée à la <em>mise en ligne.</em>
      </h2>
    </div>
    <p class="methode__intro">
      On ne filme pas juste. On pense la stratégie en amont et on porte le contenu jusqu’à son audience.
    </p>
  </div>

  <div class="timeline">
    <div class="timeline__line" aria-hidden="true"></div>
    <div class="timeline__grid">
      {steps.map((s) => (
        <div class="step">
          <div class="step__dot" style={`background:${s.bg};color:${s.titleColor}`}>{s.n}</div>
          <div class="step__card" style={`background:${s.bg};${s.dark ? 'box-shadow:4px 5px 0 rgba(34,31,24,.12);' : ''}`}>
            <div class="step__label" style={`color:${s.labelColor}`}>{s.label}</div>
            <div class="step__title" style={`color:${s.titleColor}`}>{s.title}</div>
            <p class="step__desc" style={`color:${s.textColor}`}>{s.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="methode__cta">
    <a href="#contact" class="btn btn-solid">Parler de votre projet →</a>
    <span class="methode__cta-note">Stratégie de contenu · Social media · Publicité en ligne</span>
  </div>
</section>

<style>
  .methode { padding-top: 104px; }
  .methode__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 54px;
  }
  .methode__title { max-width: 760px; }
  .methode__intro {
    font-size: 16px;
    line-height: 1.55;
    max-width: 330px;
    color: var(--text-muted);
    margin: 0;
  }

  .timeline { position: relative; }
  .timeline__line {
    position: absolute;
    top: 21px;
    left: 4%;
    right: 4%;
    border-top: 1.5px dashed #b3a079;
    z-index: 0;
  }
  .timeline__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 22px;
    position: relative;
    z-index: 1;
  }
  .step { display: flex; flex-direction: column; }
  .step__dot {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-title);
    font-weight: 800;
    font-size: 17px;
    margin-bottom: 24px;
  }
  .step__card {
    border: var(--border);
    padding: 26px;
    flex: 1;
    box-shadow: var(--shadow-sm);
  }
  .step__label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .1em;
    margin-bottom: 10px;
  }
  .step__title {
    font-family: var(--font-title);
    font-weight: 800;
    font-size: 23px;
    letter-spacing: -.02em;
    line-height: 1;
  }
  .step__desc { font-size: 14.5px; line-height: 1.5; margin: 12px 0 0; }

  .methode__cta {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-top: 38px;
    flex-wrap: wrap;
  }
  .methode__cta-note {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--label-muted);
  }

  @media (max-width: 860px) {
    .timeline__line { display: none; }
    .timeline__grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 520px) {
    .timeline__grid { grid-template-columns: 1fr; }
  }
</style>
