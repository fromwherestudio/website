---
import { Image } from 'astro:assets';
import { folders } from '../portfolio';
import { resolveProjectImage } from '../lib/images';

// rotations décoratives des "tirages" du showcase
const tilt = ['-3deg', '2.2deg', '-1.4deg', '2.8deg', '-2.2deg', '1.6deg'];
---

{folders.map((f) => (
  <dialog class="opened" id={`dlg-${f.id}`} style={`--c:${f.color}`} aria-label={`Dossier ${f.cat}`}>
    <div class="opened__inner">
      <button class="opened__close" data-close aria-label="Fermer le dossier">×</button>

      <div class="opened__tabrow">
        <span class="opened__tab" style={`color:${f.tabText}`}>DOSSIER {f.n} — {f.cat.toUpperCase()}</span>
      </div>

      <div class="opened__body">
        <div class="opened__left">
          <h2 class="opened__title">{f.title}</h2>
          <p class="opened__desc">{f.desc}</p>
          <ol class="opened__steps">
            {f.steps.map((s, i) => (
              <li class="opened__step">
                <span class="opened__step-n" style={`background:${f.color};color:${f.tabText}`}>{String(i + 1).padStart(2, '0')}</span>
                <span>{s}</span>
              </li>
            ))}
          </ol>
        </div>

        <div class="opened__right">
          <div class="opened__showcase-label">Quelques dossiers sortis du studio</div>
          <div class="opened__prints">
            {f.projects.map((p, i) => (
              <article class="print" style={`--tilt:${tilt[i % tilt.length]}`}>
                <div class="print__media hatch-soft" style={`--c:${f.color}`}>
                  {resolveProjectImage(p.image) ? (
                    <Image src={resolveProjectImage(p.image)!} alt={p.title} widths={[200, 400]} sizes="200px" class="print__img" />
                  ) : (
                    <span class="print__media-label">[ {p.title} ]</span>
                  )}
                </div>
                <div class="print__body">
                  <div class="print__title">{p.title}</div>
                  <div class="print__meta">{p.meta}</div>
                  <div class="print__stamp" style={`color:${f.tabText};border-color:${f.tabText}`}>{p.result}</div>
                </div>
              </article>
            ))}
          </div>
          <a href="/#brief" class="opened__cta">On en parle pour votre projet →</a>
        </div>
      </div>
    </div>
  </dialog>
))}

<style>
  .opened {
    width: min(1080px, 92vw);
    max-height: 90vh;
    padding: 0;
    border: var(--border);
    background: var(--paper);
    box-shadow: 10px 12px 0 rgba(34, 31, 24, .35);
    overflow: hidden;
    color: var(--ink);
  }
  .opened::backdrop {
    background: rgba(34, 31, 24, .55);
    backdrop-filter: blur(3px);
  }
  .opened[open] { animation: dlg-in .22s ease both; }
  @keyframes dlg-in {
    from { opacity: 0; transform: translateY(10px) scale(.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .opened__inner { max-height: 90vh; overflow-y: auto; position: relative; }
  .opened__close {
    position: absolute;
    top: 14px;
    right: 16px;
    z-index: 5;
    width: 40px;
    height: 40px;
    border: var(--border);
    background: var(--paper);
    font-family: var(--font-title);
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
    border-radius: 50%;
    transition: background .15s ease, color .15s ease;
  }
  .opened__close:hover { background: var(--ink); color: var(--paper); }

  .opened__tabrow { background: var(--c); border-bottom: var(--border); padding: 18px 28px; }
  .opened__tab { font-family: var(--font-mono); font-size: 12px; letter-spacing: .18em; }

  .opened__body { display: grid; grid-template-columns: 1fr 1.15fr; }
  .opened__left { padding: 38px 34px; border-right: var(--border); }
  .opened__title {
    font-family: var(--font-title);
    font-weight: 800;
    font-size: clamp(26px, 2.6vw, 36px);
    line-height: .98;
    letter-spacing: -.03em;
    margin: 0 0 18px;
  }
  .opened__desc { font-size: 15.5px; line-height: 1.6; color: var(--text-muted); margin: 0 0 26px; }
  .opened__steps { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 14px; }
  .opened__step {
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: var(--font-title);
    font-weight: 700;
    font-size: 16px;
    letter-spacing: -.01em;
  }
  .opened__step-n {
    flex: none;
    width: 34px;
    height: 34px;
    border: var(--border);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 400;
  }

  .opened__right { padding: 38px 34px; background: var(--carton-light); display: flex; flex-direction: column; }
  .opened__showcase-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--label-muted);
    margin-bottom: 22px;
  }
  .opened__prints { display: flex; flex-wrap: wrap; gap: 16px; }
  .print {
    flex: 1 1 150px;
    max-width: 200px;
    background: var(--paper);
    border: var(--border);
    box-shadow: var(--shadow-sm);
    padding: 9px 9px 0;
    transform: rotate(var(--tilt));
    transition: transform .2s ease, box-shadow .2s ease, z-index 0s;
    position: relative;
  }
  .print:hover {
    transform: rotate(0deg) translateY(-4px);
    box-shadow: 6px 8px 0 rgba(34, 31, 24, .16);
    z-index: 2;
  }
  .print__media {
    aspect-ratio: 4 / 3;
    background-color: var(--c);
    border: var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .print__media-label { font-family: var(--font-mono); font-size: 10px; color: rgba(34, 31, 24, .6); text-align: center; padding: 0 6px; }
  .print__media:has(.print__img) { background-image: none; }
  .print__img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .print__body { padding: 11px 4px 13px; }
  .print__title { font-family: var(--font-title); font-weight: 800; font-size: 16px; letter-spacing: -.02em; line-height: 1; }
  .print__meta { font-family: var(--font-mono); font-size: 9px; letter-spacing: .06em; color: var(--label-muted); margin-top: 6px; }
  .print__stamp {
    display: inline-block;
    margin-top: 10px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .03em;
    border: 1.5px dashed;
    border-radius: 3px;
    padding: 4px 7px;
    transform: rotate(-2deg);
  }

  .opened__cta {
    margin-top: auto;
    padding-top: 26px;
    font-family: var(--font-title);
    font-weight: 700;
    font-size: 16px;
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 4px;
    align-self: flex-start;
  }

  @media (max-width: 820px) {
    .opened__body { grid-template-columns: 1fr; }
    .opened__left { border-right: none; border-bottom: var(--border); }
  }
  @media (max-width: 560px) {
    .print { max-width: none; flex-basis: 130px; }
  }
</style>

<script>
  const openers = document.querySelectorAll<HTMLElement>('[data-open]');
  openers.forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-open');
      const dlg = document.getElementById(`dlg-${id}`) as HTMLDialogElement | null;
      dlg?.showModal();
    });
  });

  document.querySelectorAll<HTMLDialogElement>('dialog.opened').forEach((dlg) => {
    dlg.querySelector('[data-close]')?.addEventListener('click', () => dlg.close());
    dlg.addEventListener('click', (e) => {
      if (e.target === dlg) dlg.close();
    });
  });

  // Deep-link : ouvre automatiquement le dossier ciblé par le hash (#podcasts…)
  const openFromHash = () => {
    const id = location.hash.replace('#', '');
    if (!id) return;
    const dlg = document.getElementById(`dlg-${id}`) as HTMLDialogElement | null;
    if (dlg && !dlg.open) dlg.showModal();
  };
  openFromHash();
  window.addEventListener('hashchange', openFromHash);
</script>
